# Supabase — copy from Dashboard → Connect → ORMs → Prisma
# CRITICAL: If your password contains @ # % etc., URL-encode it (@ → %40)
# Run: .\scripts\encode-db-password.ps1
#
# DATABASE_URL = Transaction pooler, port 6543, must include pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[ENCODED_PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL = Session mode, port 5432 (migrations / db:seed only)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[ENCODED_PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

JWT_SECRET="change-this-to-a-long-random-secret-in-production"
